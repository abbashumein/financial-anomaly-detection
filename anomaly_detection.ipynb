   },
   "outputs": [],
   "source": [
    "# Re-check nulls post-clean\n",
    "print(\"Post-clean nulls - Num:\", df_num.null_count().sum_horizontal())\n",
    "print(\"Merged:\", df_merged.null_count().sum_horizontal())\n",
    "\n",
    "# Z-score for outlier detection\n",
    "df_merged = df_merged.with_columns([\n",
    "    ((pl.col('value') - pl.col('value').mean()) / pl.col('value').std()).alias('z_score')\n",
    "])\n",
    "\n",
    "outliers = df_merged.filter(pl.col('z_score').abs() > 3).height\n",
    "print(f\"Potential outliers: {outliers} rows (~{outliers/df_merged.height*100:.1f}%)\")\n",
    "\n",
    "# Date range\n",
    "print(\"Date range:\", df_merged.select([\n",
    "    pl.col('date').min().alias('min_date'),\n",
    "    pl.col('date').max().alias('max_date')\n",
    "]))\n",
    "# Save merged to Drive\n",
    "df_merged.write_parquet('/content/drive/MyDrive/anomaly-detection/data/merged_data.parquet')\n",
    "print(\"Saved merged_data.parquet to Drive\")"
   ]
  },
