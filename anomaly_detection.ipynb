    "import os\n",
    "from langchain_huggingface import HuggingFaceEmbeddings\n",
    "from langchain_community.vectorstores import FAISS\n",
    "from langchain_core.documents import Document\n",
    "from groq import Groq\n",
    "import google.generativeai as genai\n",
    "\n",
    "# Build company summaries from your real anomaly results\n",
    "company_names = ts_data['name'].to_list()\n",
    "tags_list = ts_data['tag'].to_list()\n",
    "\n",
    "docs = []\n",
    "for i in range(len(company_names)):\n",
    "    if anomalies[i]:\n",
    "        docs.append(Document(\n",
    "            page_content=f\"Company: {company_names[i]}. Metric: {tags_list[i]}. Anomaly score: {errors[i]:.4f}. Risk: HIGH.\",\n",
    "            metadata={'company': company_names[i], 'tag': tags_list[i]}\n",
    "        ))\n",
    "\n",
    "print(f\"Building RAG knowledge base from {len(docs)} flagged companies...\")\n",
    "\n",
    "# Embed and store\n",
    "embeddings = HuggingFaceEmbeddings(model_name='sentence-transformers/all-MiniLM-L6-v2')\n",
    "db = FAISS.from_documents(docs, embeddings)\n",
    "db.save_local('/content/drive/MyDrive/anomaly-detection/faiss_index')\n",
    "print(\"FAISS index saved to Drive\")\n",
    "\n",
    "# Connect LLM — put your Gemini API key here\n",
    "# Get free key from: https://aistudio.google.com\n",
    "GEMINI_API_KEY = "REMOVED"
",
    "genai.configure(api_key=GEMINI_API_KEY)\n",
    "gemini = genai.GenerativeModel('gemini-2.0-flash')\n",
    "\n",
    "groq_client = Groq(api_key=\"REMOVED\")\n",
    "\n",
    "\n",
    "def explain_anomaly(company, tag, score):\n",
    "    similar = db.similarity_search(f\"{company} {tag}\", k=3)\n",
    "    context = \"\\n\".join([d.page_content for d in similar])\n",
    "\n",
    "    response = groq_client.chat.completions.create(\n",
    "        model=\"llama-3.3-70b-versatile\",\n",
    "        messages=[{\"role\": \"user\", \"content\": f\"\"\"You are a financial fraud analyst.\n",
    "\n",
    "Company: {company}\n",
    "Metric: {tag}\n",
    "Anomaly score: {score:.4f}\n",
    "\n",
    "Similar flagged cases:\n",
    "{context}\n",
    "\n",
    "In 2 sentences explain why this is suspicious and what an auditor should investigate.\"\"\"}]\n",
    "    )\n",
    "    return response.choices[0].message.content\n",
    "\n",
    "top_idx = np.argsort(errors)[-1]\n",
    "explanation = explain_anomaly(company_names[top_idx], tags_list[top_idx], errors[top_idx])\n",
    "print(f\"Company: {company_names[top_idx]}\")\n",
    "print(f\"Metric: {tags_list[top_idx]}\")\n",
    "print(f\"Explanation: {explanation}\")"
   ]
