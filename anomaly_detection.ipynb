   "source": [
    "import plotly.graph_objects as go\n",
    "from plotly.subplots import make_subplots\n",
    "import numpy as np\n",
    "\n",
    "top_anoms = np.argsort(errors)[-5:]\n",
    "company_names = ts_data['name'].to_list()\n",
    "tags_list = ts_data['tag'].to_list()\n",
    "\n",
    "fig = make_subplots(\n",
    "    rows=1, cols=5,\n",
    "    subplot_titles=[f'{company_names[i][:15]}\\n{tags_list[i][:10]}\\nError:{errors[i]:.2f}' for i in top_anoms]\n",
    ")\n",
    "\n",
    "for idx, i in enumerate(top_anoms):\n",
    "    col = idx + 1\n",
    "    fig.add_trace(go.Scatter(\n",
    "        y=padded_data[i], mode='lines+markers',\n",
    "        name='Original', line=dict(color='blue')), row=1, col=col)\n",
    "    fig.add_trace(go.Scatter(\n",
    "        y=recon[i].detach().numpy(), mode='lines+markers',\n",
    "        name='Reconstructed', line=dict(color='red')), row=1, col=col)\n",
    "\n",
    "fig.update_layout(\n",
    "    title='Top 5 Anomalies: Original vs Reconstructed (Real SEC Companies)',\n",
    "    height=400, showlegend=True\n",
    ")\n",
    "fig.show()\n",
    "\n",
    "# Print which companies were flagged\n",
    "print(\"\\nTop 5 most anomalous companies:\")\n",
    "for i in top_anoms:\n",
    "    print(f\"  {company_names[i]} | {tags_list[i]} | Error: {errors[i]:.4f}\")"
   ]
  },
