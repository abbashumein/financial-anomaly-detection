    "from sklearn.ensemble import IsolationForest\n",
    "from sklearn.metrics import roc_auc_score\n",
    "\n",
    "# Isolation Forest baseline\n",
    "iso = IsolationForest(contamination=0.05, random_state=42)\n",
    "iso_preds = iso.fit_predict(padded_data)\n",
    "iso_anomalies = iso_preds == -1\n",
    "\n",
    "# Compare VAE vs Isolation Forest\n",
    "vae_binary = anomalies.astype(int)\n",
    "iso_binary = iso_anomalies.astype(int)\n",
    "\n",
    "agreement = (vae_binary == iso_binary).sum()\n",
    "print(f\"VAE anomalies: {vae_binary.sum()}\")\n",
    "print(f\"Isolation Forest anomalies: {iso_binary.sum()}\")\n",
    "print(f\"Both agree on: {agreement} sequences ({agreement/len(vae_binary)*100:.1f}%)\")\n",
    "\n",
    "auroc = roc_auc_score(iso_binary, vae_binary)\n",
    "print(f\"AUROC score: {auroc:.4f}\")"
   ]
