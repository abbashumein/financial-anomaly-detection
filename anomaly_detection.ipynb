    "import os\n",
    "import zipfile\n",
    "\n",
    "data_path = '/content/drive/MyDrive/anomaly-detection/data'\n",
    "\n",
    "zip_files = ['2024q4.zip', '2025q1.zip', '2025q2.zip', '2025q3.zip', '2025q4.zip', '2026q1.zip']\n",
    "\n",
    "for zf in zip_files:\n",
    "    quarter = zf.replace('.zip', '')\n",
    "    zip_path = os.path.join(data_path, zf)\n",
    "    extract_path = os.path.join(data_path, quarter)\n",
    "\n",
    "    if os.path.exists(extract_path) and os.listdir(extract_path):\n",
    "        print(f\"{quarter} — already extracted, skipping\")\n",
    "        continue\n",
    "\n",
    "    os.makedirs(extract_path, exist_ok=True)\n",
    "    with zipfile.ZipFile(zip_path, 'r') as z:\n",
    "        z.extractall(extract_path)\n",
    "    print(f\"{quarter} — extracted: {os.listdir(extract_path)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4",
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
