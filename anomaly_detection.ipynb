   "source": [
    "import polars as pl\n",
    "\n",
    "data_path = '/content/drive/MyDrive/anomaly-detection/data'\n",
    "quarters = ['2024q4', '2025q1', '2025q2', '2025q3', '2025q4', '2026q1']\n",
    "\n",
    "df_num_list = []\n",
    "df_sub_list = []\n",
    "\n",
    "for q in quarters:\n",
    "    folder = os.path.join(data_path, q)\n",
    "    print(f\"Loading {q}...\")\n",
    "\n",
    "    df_num_list.append(pl.read_csv(\n",
    "        os.path.join(folder, 'num.txt'),\n",
    "        separator='\\t', infer_schema_length=10000, ignore_errors=True\n",
    "    ).with_columns(pl.lit(q).alias('quarter')))\n",
    "\n",
    "    df_sub_list.append(pl.read_csv(\n",
    "        os.path.join(folder, 'sub.txt'),\n",
    "        separator='\\t', infer_schema_length=10000, ignore_errors=True\n",
    "    ).with_columns(pl.lit(q).alias('quarter')))\n",
    "\n",
    "df_num = pl.concat(df_num_list, how='vertical_relaxed')\n",
    "df_sub = pl.concat(df_sub_list, how='vertical_relaxed')\n",
    "\n",
    "print(f\"\\nCombined num shape: {df_num.shape}\")\n",
    "print(f\"Combined sub shape: {df_sub.shape}\")\n",
    "\n",
    "# SAVE TO DRIVE — permanent, never reload raw files again\n",
    "df_num.write_parquet(os.path.join(data_path, 'combined_num.parquet'))\n",
    "df_sub.write_parquet(os.path.join(data_path, 'combined_sub.parquet'))\n",
    "print(\"\\nSaved combined_num.parquet and combined_sub.parquet to Drive\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5",
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "f6e8e268-d271-4bc1-a9d9-c6d6fe9798ca",
    "outputId": "d04a83bf-bac1-455b-a351-c5b8c100138a"
   },
   "outputs": [],
   "source": [
    "import polars as pl\n",
    "\n",
    "data_path = '/content/drive/MyDrive/anomaly-detection/data'\n",
    "\n",
    "# Load tag from one quarter (same across all quarters)\n",
    "df_tag = pl.read_csv(\n",
    "    f'{data_path}/2024q4/tag.txt',\n",
    "    separator='\\t', infer_schema_length=10000, ignore_errors=True\n",
    ")\n",
    "\n",
    "# Clean\n",
    "df_num = df_num.unique(subset=['adsh', 'tag']).with_columns(pl.col('value').fill_null(0))\n",
    "df_sub = df_sub.unique(subset=['adsh'])\n",
    "df_tag = df_tag.unique(subset=['tag'])\n",
    "\n",
    "# Date conversion\n",
    "df_num = df_num.with_columns(\n",
    "    pl.col('ddate').cast(str).str.replace(' ', '').str.strptime(pl.Date, '%Y%m%d', strict=False).alias('date')\n",
    ")\n",
    "\n",
    "# Filter key financial tags\n",
    "key_tags = df_tag.filter(\n",
    "    pl.col('tag').str.contains(r'Revenue|Asset|Liabilit|Income', literal=False)\n",
    ").select('tag').unique()\n",
    "\n",
    "df_filtered = df_num.filter(pl.col('tag').is_in(key_tags['tag']))\n",
    "\n",
    "# Merge with company details\n",
    "df_merged = df_filtered.join(\n",
    "    df_sub.select(['adsh', 'cik', 'name', 'period', 'quarter']),\n",
    "    on='adsh', how='left'\n",
    ")\n",
    "\n",
    "print(f\"Key tags found: {key_tags.shape[0]}\")\n",
    "print(f\"Merged shape: {df_merged.shape}\")\n",
    "print(df_merged.head(3))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
