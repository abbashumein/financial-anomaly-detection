   "source": [
    "from langgraph.graph import StateGraph, END\n",
    "from typing import TypedDict\n",
    "\n",
    "# Define agent state\n",
    "class AnomalyState(TypedDict):\n",
    "    company: str\n",
    "    tag: str\n",
    "    score: float\n",
    "    risk_level: str\n",
    "    similar_cases: str\n",
    "    explanation: str\n",
    "    final_report: str\n",
    "\n",
    "# Node 1 — assess risk level\n",
    "def assess_risk(state: AnomalyState) -> AnomalyState:\n",
    "    score = state['score']\n",
    "    if score > 0.5:\n",
    "        risk = \"HIGH\"\n",
    "    elif score > 0.3:\n",
    "        risk = \"MEDIUM\"\n",
    "    else:\n",
    "        risk = \"LOW\"\n",
    "    state['risk_level'] = risk\n",
    "    return state\n",
    "\n",
    "# Node 2 — retrieve similar cases\n",
    "def retrieve_context(state: AnomalyState) -> AnomalyState:\n",
    "    similar = db.similarity_search(f\"{state['company']} {state['tag']}\", k=3)\n",
    "    state['similar_cases'] = \"\\n\".join([d.page_content for d in similar])\n",
    "    return state\n",
    "\n",
    "# Node 3 — generate explanation\n",
    "def generate_explanation(state: AnomalyState) -> AnomalyState:\n",
    "    response = groq_client.chat.completions.create(\n",
    "        model=\"llama-3.3-70b-versatile\",\n",
    "        messages=[{\"role\": \"user\", \"content\": f\"\"\"Financial fraud analyst. Based only on provided data.\n",
    "Company: {state['company']}\n",
    "Metric: {state['tag']}\n",
    "Risk: {state['risk_level']}\n",
    "Similar cases: {state['similar_cases']}\n",
    "In 2 sentences explain what is suspicious.\"\"\"}]\n",
    "    )\n",
    "    state['explanation'] = response.choices[0].message.content\n",
    "    return state\n",
    "\n",
    "# Node 4 — write final report\n",
    "def write_report(state: AnomalyState) -> AnomalyState:\n",
    "    state['final_report'] = f\"\"\"\n",
    "=== ANOMALY REPORT ===\n",
    "Company: {state['company']}\n",
    "Metric: {state['tag']}\n",
    "Anomaly Score: {state['score']:.4f}\n",
    "Risk Level: {state['risk_level']}\n",
    "Explanation: {state['explanation']}\n",
    "======================\"\"\"\n",
    "    return state\n",
    "\n",
    "# Build agent graph\n",
    "graph = StateGraph(AnomalyState)\n",
    "graph.add_node(\"assess_risk\", assess_risk)\n",
    "graph.add_node(\"retrieve_context\", retrieve_context)\n",
    "graph.add_node(\"generate_explanation\", generate_explanation)\n",
    "graph.add_node(\"write_report\", write_report)\n",
    "\n",
    "graph.set_entry_point(\"assess_risk\")\n",
    "graph.add_edge(\"assess_risk\", \"retrieve_context\")\n",
    "graph.add_edge(\"retrieve_context\", \"generate_explanation\")\n",
    "graph.add_edge(\"generate_explanation\", \"write_report\")\n",
    "graph.add_edge(\"write_report\", END)\n",
    "\n",
    "agent = graph.compile()\n",
    "\n",
    "# Run on top anomaly\n",
    "top_idx = np.argsort(errors)[-1]\n",
    "result = agent.invoke({\n",
    "    \"company\": company_names[top_idx],\n",
    "    \"tag\": tags_list[top_idx],\n",
    "    \"score\": float(errors[top_idx]),\n",
    "    \"risk_level\": \"\",\n",
    "    \"similar_cases\": \"\",\n",
    "    \"explanation\": \"\",\n",
    "    \"final_report\": \"\"\n",
    "})\n",
    "\n",
    "print(result['final_report'])"
   ]
  },
