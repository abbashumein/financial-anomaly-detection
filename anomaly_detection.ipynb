    "def explain_anomaly_safe(company, tag, score):\n",
    "    similar = db.similarity_search(f\"{company} {tag}\", k=3)\n",
    "    context = \"\\n\".join([d.page_content for d in similar])\n",
    "\n",
    "    prompt = f\"\"\"You are a financial fraud analyst. Answer ONLY based on the data provided below.\n",
    "Do NOT invent facts, numbers, or company history not present in the context.\n",
    "If you are unsure, say \"requires further investigation\" instead of guessing.\n",
    "\n",
    "Company: {company}\n",
    "Metric: {tag}\n",
    "Anomaly score: {score:.4f}\n",
    "\n",
    "Retrieved context:\n",
    "{context}\n",
    "\n",
    "In 2 sentences, explain what is suspicious and what an auditor should check.\"\"\"\n",
    "\n",
    "    response = groq_client.chat.completions.create(\n",
    "        model=\"llama-3.3-70b-versatile\",\n",
    "        messages=[{\"role\": \"user\", \"content\": prompt}]\n",
    "    )\n",
    "\n",
    "    result = response.choices[0].message.content\n",
    "\n",
    "    # Basic guardrail — block if LLM invents specific numbers not in context\n",
    "    forbidden = [\"according to my knowledge\", \"historically\", \"in previous years\", \"I know that\"]\n",
    "    for phrase in forbidden:\n",
    "        if phrase.lower() in result.lower():\n",
    "            return \"Explanation blocked by guardrails — response contained ungrounded claims. Requires human review.\"\n",
    "\n",
    "    return result\n",
    "\n",
    "# Test it\n",
    "top_idx = np.argsort(errors)[-1]\n",
    "safe_explanation = explain_anomaly_safe(\n",
    "    company_names[top_idx],\n",
    "    tags_list[top_idx],\n",
    "    errors[top_idx]\n",
    ")\n",
    "print(f\"Company: {company_names[top_idx]}\")\n",
    "print(f\"Safe explanation: {safe_explanation}\")"
   ]
